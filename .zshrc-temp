# Print a separate line with useful info before the prompt
function precmd() {
    if [ "$TERMINAL_EMULATOR" = "JetBrains-JediTerm" ] ; then
        return
    fi

    exit_code=$?

    red='\e[1;31m'
    green='\e[1;32m'
    blue='\e[1;34m'
    cyan='\e[1;36m'
    normal='\e[0m'

    # Recognise the Copilot terminal and print a special prompt there
    if [ "$GIT_PAGER" = 'cat' ] ; then
        printf "${cyan}🤖 Copilot Terminal${normal}\n"
        return
    fi

    if [ $exit_code -eq 0 ] ; then
        ec="${green}\u2713${normal}"
    else
        ec="${red}\u2717${normal}"
    fi

    ts=$(date +%H:%M:%S)

    if [ $PWD = $HOME ] ; then
        dir='~'
    else
        dir=$(basename $PWD)
    fi

    tf=''
    if [ -d ".terraform" ] ; then
        tf="($(terraform workspace show))"
    fi

    gc=$(gcloud-which)
    if [ "$gc" = "nordnet" ] ; then
        gc="${cyan}N${tf}${normal}"
    elif [ "$gc" = "private" ] ; then
        gc="${blue}P${tf}${normal}"
    elif [ "$gc" = "maglo" ] ; then
        gc="${red}M${tf}${normal}"
    else
        gc="?"
    fi

    if git status > /dev/null 2>&1 ; then
        mod=$(git status --porcelain | wc -l)
        git_status=""
        if [ $mod -gt 0 ] ; then
            git_status="${green}+"
        fi
        git_branch=$(git branch | sed -n '/\* /s///p')
        git_info="${blue}${git_branch}${git_status}${normal} "
    else
        git_info=""
    fi

    printf "${ec} ${ts} ${gc} ${cyan}${dir}${normal} ${git_info}\n"
}

if [ "$TERMINAL_EMULATOR" != "JetBrains-JediTerm" ] ; then
    PROMPT=$(printf "\u2192 ")
fi

CDPATH=~/work:~/myproj

PATH="$PATH:/Applications/Visual Studio Code.app/Contents/Resources/app/bin"
# VS Code shell integration adds a lot of totally stupid and useless behavior, but Copilot Terminal needs it
if [[ "$TERM_PROGRAM" == 'vscode' ]] ; then
    . "$(code --locate-shell-integration-path $(basename $SHELL))"
fi

export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"  # This loads nvm
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"  # This loads nvm bash_completion

# Claude Code
export CLAUDE_CODE_USE_VERTEX=1
export CLOUD_ML_REGION=europe-west1
export ANTHROPIC_VERTEX_PROJECT_ID=ai-dev-tools-prod-57391
export GITHUB_PERSONAL_ACCESS_TOKEN=$(cat ~/secrets/my-github-token)

# Override many BSD command-line utilities with their GNU counterparts
for package in coreutils gawk gnu-sed gnu-tar ; do
    PATH="$(brew --prefix)/opt/${package}/libexec/gnubin:$PATH"
done
# When building Backstage, it is common to fail if there are
# GNU tools (particularly libtool) in the path. Use this function to get them
# off the path.
function ungnu() {
    PATH=$(echo $PATH | sed 's|[^:]*/gnubin:||g')
}

function vpn() {
    if [ "$1" = "on" ] ; then
        sudo ansible localhost -c local -m lineinfile -a 'path=/etc/hosts state=absent regexp="vpn\.nordnet\.se"'
    elif [ "$1" = "off" ] ; then
        sudo ansible localhost -c local -m lineinfile -a 'path=/etc/hosts state=present line="127.0.0.2    vpn.nordnet.se"'
    else
        grep -Fq vpn.nordnet.se /etc/hosts && echo "off" || echo "on"
    fi
}

function ggn () {
    # The sed is to add a space after the second colon, so the output line becomes clickable in an IDE console
    git grep -n "$@" | sed 's/:\([0-9]*\):/:\1: /'
}

function ggin () {
    # The sed is to add a space after the second colon, so the output line becomes clickable in an IDE console
    git grep -in "$@" | sed 's/:\([0-9]*\):/:\1: /'
}

function venv () {
    [ -d venv ] || python3 -m venv venv
    source venv/bin/activate
}

